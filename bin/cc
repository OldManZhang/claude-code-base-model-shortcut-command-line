#!/bin/bash

# cc - Claude Command Line Manager
# A tool to switch between different LLM providers

set -e

# Configuration directory - use CC_PATH if set, otherwise default to ~/.cc
CC_PATH="${CC_PATH:-$HOME/.cc}"
CONFIGS_DIR="${CC_PATH}/configs"
MODELS_CONFIG="${CC_PATH}/models.config"

# Check for jq
check_jq() {
    if ! command -v jq &> /dev/null; then
        echo "Error: jq is required but not installed."
        echo "Please install jq:"
        echo "  macOS: brew install jq"
        echo "  Linux: sudo apt install jq"
        exit 1
    fi
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Check if new models.config exists
has_models_config() {
    [ -f "$MODELS_CONFIG" ] && [ -s "$MODELS_CONFIG" ]
}

# Get provider config from models.config
get_provider_config() {
    local provider="$1"
    local field="$2"  # base_url, api_key

    if [ ! -f "$MODELS_CONFIG" ]; then
        return 1
    fi

    jq -r ".providers | to_entries | .[] | select(.key == \"$provider\") | .value.${field}" "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$" || return 1
}

# Check if a name is a provider
is_provider() {
    local name="$1"
    local result
    result=$(jq -r ".providers | to_entries | .[] | select(.key == \"$name\") | .value" "$MODELS_CONFIG" 2>/dev/null)
    [ -n "$result" ] && [ "$result" != "null" ]
}

# Get model/alias config from models.config
get_model_config() {
    local model="$1"
    local field="$2"  # provider, id

    if [ ! -f "$MODELS_CONFIG" ]; then
        return 1
    fi

    # Use to_entries to handle keys with special characters like hyphens
    local result
    result=$(jq -r ".models | to_entries | .[] | select(.key == \"$model\") | .value.${field}" "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$")

    if [ -n "$result" ]; then
        echo "$result"
        return 0
    fi

    # Check if it's an alias (simple string value)
    result=$(jq -r ".models | to_entries | .[] | select(.key == \"$model\") | .value" "$MODELS_CONFIG" 2>/dev/null)
    if [[ "$result" == \"*\" ]]; then
        # It's an alias, resolve it
        local target="${result//\"/}"
        get_model_config "$target" "$field"
    else
        return 1
    fi
}

# Get default from models.config
get_default() {
    if [ ! -f "$MODELS_CONFIG" ]; then
        return 1
    fi

    jq -r '.default' "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$" || return 1
}

# Check if name is defined in config
get_config_entry() {
    local name="$1"

    if [ ! -f "$MODELS_CONFIG" ]; then
        return 1
    fi

    # Check providers
    local result
    result=$(jq -r ".providers | to_entries | .[] | select(.key == \"$name\") | .value" "$MODELS_CONFIG" 2>/dev/null)
    if [ -n "$result" ] && [ "$result" != "null" ]; then
        echo "provider"
        return 0
    fi

    # Check models
    result=$(jq -r ".models | to_entries | .[] | select(.key == \"$name\") | .value" "$MODELS_CONFIG" 2>/dev/null)
    if [ -n "$result" ] && [ "$result" != "null" ]; then
        echo "model"
        return 0
    fi

    return 1
}

# Resolve alias to final model name
resolve_alias() {
    local name="$1"
    local result

    result=$(jq -r ".models.${name}" "$MODELS_CONFIG" 2>/dev/null)

    if [[ "$result" == \"*\" ]]; then
        # It's an alias
        local target="${result//\"/}"
        echo "$target"
    else
        echo "$name"
    fi
}

# Load from models.config
load_from_models_config() {
    local input="$1"
    local explicit_model="$2"

    local provider=""
    local model=""

    if is_provider "$input"; then
        provider="$input"
        model="$explicit_model"
    else
        # It's an alias
        provider=$(get_model_config "$input" "provider")
        model=$(get_model_config "$input" "id")
    fi

    if [ -z "$provider" ]; then
        print_error "Cannot determine provider for: $input"
        return 1
    fi

    local base_url=$(get_provider_config "$provider" "base_url")
    local api_key=$(get_provider_config "$provider" "api_key")

    if [ -z "$base_url" ] || [ -z "$api_key" ]; then
        print_error "Provider '$provider' not found in $MODELS_CONFIG"
        return 1
    fi

    export ANTHROPIC_BASE_URL="$base_url"
    export ANTHROPIC_AUTH_TOKEN="$api_key"
    if [ -n "$model" ]; then
        export ANTHROPIC_MODEL="$model"
    fi

    print_success "Configuration loaded for $provider"
    if [ -n "$model" ]; then
        print_info "Model: $model"
    fi
}

# Extract provider name from env.* file
get_provider_name() {
    basename "$1" | sed 's/^env\.//'
}

# Check if a provider exists (in either old env.* or new models.config)
provider_exists() {
    local provider="$1"
    # Check old-style env.* config
    [ -f "$CONFIGS_DIR/env.$provider" ] && return 0
    # Check new models.config
    has_models_config && is_provider "$provider" && return 0
    return 1
}

# List all available configs
list_configs() {
    print_info "Available configurations:"
    echo

    echo "Environment variables:"
    echo "  CC_PATH=${CC_PATH:-<not set>}"
    echo "  CC_DEFAULT_PROVIDER=${CC_DEFAULT_PROVIDER:-<not set>}"
    echo "  LLM_PROVIDER=${LLM_PROVIDER:-<not set>}"
    echo

    if has_models_config; then
        echo "Configuration file: $MODELS_CONFIG (JSON format)"
    elif [ -d "$CONFIGS_DIR" ]; then
        echo "Configuration directory: $CONFIGS_DIR (legacy env.* format)"
    else
        echo "No configuration found"
    fi
    echo

    local default_provider="${CC_DEFAULT_PROVIDER:-}"

    if has_models_config; then
        if [ -z "$default_provider" ]; then
            default_provider=$(get_default 2>/dev/null || echo "")
        fi

        # List providers
        print_info "Providers:"
        for prov in $(jq -r '.providers | keys[]' "$MODELS_CONFIG" 2>/dev/null); do
            local current_marker=""
            local default_marker=""

            if [ -n "$LLM_PROVIDER" ] && [ "$LLM_PROVIDER" = "$prov" ]; then
                current_marker=" $(print_success "[current]")"
            fi

            if [ "$prov" = "$default_provider" ]; then
                default_marker=" $(print_info "[default]")"
            fi

            echo -e "  ${GREEN}$prov${NC}$current_marker$default_marker"
        done

        # List models/aliases
        print_info "Models/Aliases:"
        for model in $(jq -r '.models | keys[]' "$MODELS_CONFIG" 2>/dev/null); do
            local provider=$(get_model_config "$model" "provider" 2>/dev/null || echo "")
            local id=$(get_model_config "$model" "id" 2>/dev/null || echo "")

            if [ -n "$provider" ] && [ -n "$id" ]; then
                echo -e "  ${YELLOW}$model${NC} ($provider:$id)"
            else
                echo -e "  ${YELLOW}$model${NC}"
            fi
        done
    elif [ -d "$CONFIGS_DIR" ]; then
        # Legacy env.* format
        local count=0
        for config in "$CONFIGS_DIR"/env.*; do
            if [ -f "$config" ]; then
                local name=$(get_provider_name "$config")
                local current_marker=""
                local default_marker=""

                if [ -n "$LLM_PROVIDER" ] && [ "$LLM_PROVIDER" = "$name" ]; then
                    current_marker=" $(print_success "[current]")"
                fi

                if [ -n "$default_provider" ] && [ "$name" = "$default_provider" ]; then
                    default_marker=" $(print_info "[default]")"
                elif [ "$name" = "kimi" ] && [ -z "$default_provider" ]; then
                    default_marker=" $(print_info "[default]")"
                fi

                echo -e "  ${GREEN}$name${NC}$current_marker$default_marker"
                count=$((count + 1))
            fi
        done

        if [ $count -eq 0 ]; then
            print_warning "No configurations found in $CONFIGS_DIR/env.*"
        fi
    else
        print_warning "No configurations found"
    fi
}

# Show current configuration
show_current() {
    print_info "Current configuration status:"
    echo

    echo "Environment variables:"
    echo "  CC_PATH=${CC_PATH:-<not set>}"
    echo "  CC_DEFAULT_PROVIDER=${CC_DEFAULT_PROVIDER:-<not set>}"
    echo "  LLM_PROVIDER=${LLM_PROVIDER:-<not set>}"
    echo

    if has_models_config; then
        echo "Configuration file: $MODELS_CONFIG"
    else
        echo "Configuration directory: $CONFIGS_DIR"
    fi
    echo

    if [ -n "$LLM_PROVIDER" ]; then
        print_info "Active provider: $LLM_PROVIDER"
        echo

        if has_models_config && is_provider "$LLM_PROVIDER"; then
            local base_url=$(get_provider_config "$LLM_PROVIDER" "base_url")
            local api_key=$(get_provider_config "$LLM_PROVIDER" "api_key")
            echo "Configuration:"
            echo "  base_url: $base_url"
            echo "  api_key: ****"
        else
            local config_file="$CONFIGS_DIR/env.$LLM_PROVIDER"
            if [ -f "$config_file" ]; then
                echo "Configuration file: $config_file"
                echo
                echo "Environment variables from config:"
                grep "^export" "$config_file" | sed 's/^/  /'
            else
                print_warning "Configuration file for $LLM_PROVIDER not found at: $config_file"
            fi
        fi
    else
        print_warning "No configuration is currently active"
    fi
}

load_config() {
    local input="$1"
    shift

    if [ -z "$input" ]; then
        print_error "Provider/alias name is required"
        echo
        print_info "Usage: cc <provider> or cc <alias>"
        echo
        list_configs
        exit 1
    fi

    # Check if input is an alias first
    local is_alias=false
    if has_models_config && get_config_entry "$input" 2>/dev/null | grep -q "model"; then
        is_alias=true
    fi

    local provider="$input"
    local model=""

    if [ "$is_alias" = true ]; then
        # It's an alias - resolve it
        provider=$(get_model_config "$input" "provider")
        model=$(get_model_config "$input" "id")
    elif [[ "$input" == *":"* ]]; then
        # Parse provider:model syntax
        provider="${input%%:*}"
        model="${input#*:}"
    fi

    # Check if provider exists in models.config first, then fall back to env.*
    local use_models_config=false

    # If it's an alias, we already have provider and model
    if [ "$is_alias" = true ]; then
        use_models_config=true
    elif has_models_config && is_provider "$provider"; then
        use_models_config=true
    elif [ ! -f "$CONFIGS_DIR/env.$provider" ]; then
        print_error "Configuration for '$provider' not found"
        echo
        print_info "Available configurations:"
        list_configs
        exit 1
    fi

    local claude_args=("$@")

    if [ "$use_models_config" = true ]; then
        if [ -n "$model" ]; then
            print_info "Loading $provider with model $model..."
        else
            print_info "Loading configuration for $provider..."
        fi
        echo

        # Set environment variables directly
        local base_url=$(get_provider_config "$provider" "base_url")
        local api_key=$(get_provider_config "$provider" "api_key")

        if [ -z "$base_url" ] || [ -z "$api_key" ]; then
            print_error "Provider '$provider' not found in $MODELS_CONFIG"
            exit 1
        fi

        export ANTHROPIC_BASE_URL="$base_url"
        export ANTHROPIC_AUTH_TOKEN="$api_key"
        if [ -n "$model" ]; then
            export ANTHROPIC_MODEL="$model"
        fi

        print_success "Configuration loaded for $provider"
        if [ -n "$model" ]; then
            print_info "Model: $model"
        fi

        echo
        print_success "Now you can use Claude with $provider configuration"
        echo

        if command -v claude &> /dev/null; then
            print_info "Starting Claude CLI..."
            echo
            claude "${claude_args[@]}"
        else
            print_warning "Claude CLI not found in PATH"
            print_info "Make sure Claude CLI is installed"
        fi
    else
        # Use old-style env.* config
        local config_file="$CONFIGS_DIR/env.$provider"

        print_info "Loading configuration for $provider..."
        echo

        source "$config_file"

        print_success "Configuration loaded for $provider"
        echo

        if command -v claude &> /dev/null; then
            print_info "Starting Claude CLI..."
            echo
            claude "${claude_args[@]}"
        else
            print_warning "Claude CLI not found in PATH"
        fi
    fi
}

load_default_config() {
    local args=("$@")

    local default_provider="${CC_DEFAULT_PROVIDER:-}"

    if [ -z "$default_provider" ] && has_models_config; then
        default_provider=$(get_default 2>/dev/null || echo "")
    fi

    if [ -z "$default_provider" ]; then
        if provider_exists "kimi"; then
            default_provider="kimi"
            print_info "Using default provider: kimi"
            echo
        else
            print_warning "No default provider is set"
            echo
            print_info "Please specify a provider:"
            echo
            list_configs
            exit 1
        fi
    else
        print_info "Using default provider: $default_provider"
        echo
    fi

    load_config "$default_provider" "${args[@]}"
}

show_usage() {
    echo "Usage: cc [provider] [arguments...]"
    echo
    echo "Arguments:"
    echo "  provider            LLM provider to use (kimi, glm, openai, etc.)"
    echo "                     Or model alias (gpt4, claude-sonnet, etc.)"
    echo "                     Or provider:model (e.g., kimi:gpt-4o)"
    echo "  arguments           Additional arguments passed to claude CLI"
    echo
    echo "Commands:"
    echo "  <provider>          Switch to specified provider"
    echo "  <alias>            Use model alias"
    echo "  <provider>:<model> Switch to provider with specific model"
    echo "  list, ls           List all available configurations"
    echo "  current            Show current configuration"
    echo "  help, -h, --help   Show this help message"
    echo
    echo "Configuration:"
    echo "  JSON config: $MODELS_CONFIG"
    echo "  Legacy: $CONFIGS_DIR/env.*"
    echo
    echo "Examples:"
    echo "  cc                  Use default provider"
    echo "  cc kimi             Switch to kimi"
    echo "  cc gpt4             Use gpt4 alias"
    echo "  cc minimax-m2.5     Use minimax-m2.5 alias"
    echo "  cc list             List all providers"
}

main() {
    # Check for jq first
    check_jq

    local command="${1:-}"

    case "$command" in
        help|-h|--help)
            show_usage
            exit 0
            ;;
        list|ls)
            list_configs
            exit 0
            ;;
        current)
            show_current
            exit 0
            ;;
        "")
            load_default_config
            exit $?
            ;;
        *)
            # Check if it's a provider or an alias
            if provider_exists "$command"; then
                load_config "$@"
            elif has_models_config && get_config_entry "$command" &>/dev/null; then
                load_config "$command"
            else
                load_default_config "$@"
            fi
            exit $?
            ;;
    esac
}

main "$@"
