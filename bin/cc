#!/bin/bash

# cc - Claude Command Line Manager
# A tool to switch between different LLM providers

set -e

# Configuration directory - use CC_PATH if set, otherwise default to ~/.cc
CC_PATH="${CC_PATH:-$HOME/.cc}"
CONFIGS_DIR="${CC_PATH}/configs"
MODELS_CONFIG="${CC_PATH}/models.config"

# Dry-run mode flag
dry_run=0

# Check for jq
check_jq() {
    if ! command -v jq &> /dev/null; then
        echo "Error: jq is required but not installed."
        echo "Please install jq:"
        echo "  macOS: brew install jq"
        echo "  Linux: sudo apt install jq"
        exit 1
    fi
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Check if new models.config exists
has_models_config() {
    [ -f "$MODELS_CONFIG" ] && [ -s "$MODELS_CONFIG" ]
}

# Get provider config from models.config
get_provider_config() {
    local provider="$1"
    local field="$2"  # base_url, api_key

    if [ ! -f "$MODELS_CONFIG" ]; then
        return 1
    fi

    jq -r ".providers[\"$provider\"].${field}" "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$" || return 1
}

# Check if a provider exists
is_provider() {
    local name="$1"
    jq -r ".providers[\"$name\"]" "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$" > /dev/null
}

# Check if a model exists under a provider
model_exists() {
    local provider="$1"
    local model="$2"
    jq -r ".providers[\"$provider\"].models[\"$model\"]" "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$" > /dev/null
}

# Get default from models.config (format: "provider:model")
get_default() {
    if [ ! -f "$MODELS_CONFIG" ]; then
        return 1
    fi

    jq -r '.default' "$MODELS_CONFIG" 2>/dev/null | grep -v "^null$" || return 1
}

# Extract provider name from env.* file
get_provider_name() {
    basename "$1" | sed 's/^env\.//'
}

# Check if a provider exists (in either old env.* or new models.config)
provider_exists() {
    local provider="$1"
    # Check old-style env.* config
    [ -f "$CONFIGS_DIR/env.$provider" ] && return 0
    # Check new models.config
    has_models_config && is_provider "$provider" && return 0
    return 1
}

# List all available configs
list_configs() {
    print_info "Available configurations:"
    echo

    echo "Environment variables:"
    echo "  CC_PATH=${CC_PATH:-<not set>}"
    echo "  LLM_PROVIDER=${LLM_PROVIDER:-<not set>}"
    echo

    if has_models_config; then
        echo "Configuration file: $MODELS_CONFIG (JSON format)"
    elif [ -d "$CONFIGS_DIR" ]; then
        echo "Configuration directory: $CONFIGS_DIR (legacy env.* format)"
    else
        echo "No configuration found"
    fi
    echo


    if has_models_config; then
        local default=$(get_default 2>/dev/null || echo "")

        # List providers and their models
        print_info "Providers:"
        for prov in $(jq -r '.providers | keys[]' "$MODELS_CONFIG" 2>/dev/null); do
            local current_marker=""
            local default_marker=""

            if [ -n "$LLM_PROVIDER" ] && [ "$LLM_PROVIDER" = "$prov" ]; then
                current_marker=" [current]"
            fi

            if [ "$default" = "$prov"* ]; then
                default_marker=" [default]"
            fi

            echo -e "  ${GREEN}${prov}${NC}${current_marker}${default_marker}"
        done

        # List models under each provider
        echo
        print_info "Models:"
        for prov in $(jq -r '.providers | keys[]' "$MODELS_CONFIG" 2>/dev/null); do
            local models=$(jq -r ".providers[\"$prov\"].models | keys[]" "$MODELS_CONFIG" 2>/dev/null)
            if [ -n "$models" ]; then
                for model in $models; do
                    local enable=$(jq -r ".providers[\"$prov\"].models[\"$model\"].enable // true" "$MODELS_CONFIG" 2>/dev/null)
                    local default_marker=""
                    if [ "$default" = "$prov:$model" ]; then
                        default_marker=" [default]"
                    fi
                    if [ "$enable" = "true" ]; then
                        echo -e "  ${YELLOW}${prov}:${model}${NC}${default_marker}"
                    else
                        echo -e "  ${YELLOW}${prov}:${model}${NC}${default_marker} (disabled)"
                    fi
                done
            fi
        done
    elif [ -d "$CONFIGS_DIR" ]; then
        # Legacy env.* format
        local count=0
        for config in "$CONFIGS_DIR"/env.*; do
            if [ -f "$config" ]; then
                local name=$(get_provider_name "$config")
                local current_marker=""
                local default_marker=""

                if [ -n "$LLM_PROVIDER" ] && [ "$LLM_PROVIDER" = "$name" ]; then
                    current_marker=" $(print_success "[current]")"
                fi

                if [ -n "$default_provider" ] && [ "$name" = "$default_provider" ]; then
                    default_marker=" $(print_info "[default]")"
                elif [ "$name" = "kimi" ] && [ -z "$default_provider" ]; then
                    default_marker=" $(print_info "[default]")"
                fi

                echo -e "  ${GREEN}$name${NC}$current_marker$default_marker"
                count=$((count + 1))
            fi
        done

        if [ $count -eq 0 ]; then
            print_warning "No configurations found in $CONFIGS_DIR/env.*"
        fi
    else
        print_warning "No configurations found"
    fi

    echo
    echo "Tip: Set env vars to use directly:"
    echo "  export ANTHROPIC_BASE_URL=https://api.example.com"
    echo "  export ANTHROPIC_AUTH_TOKEN=your-api-key"
    echo "  claude  # Run claude directly"
}

# Show current configuration
show_current() {
    print_info "Current configuration status:"
    echo

    echo "Environment variables:"
    echo "  CC_PATH=${CC_PATH:-<not set>}"
    echo "  LLM_PROVIDER=${LLM_PROVIDER:-<not set>}"
    echo

    if has_models_config; then
        echo "Configuration file: $MODELS_CONFIG"
    else
        echo "Configuration directory: $CONFIGS_DIR"
    fi
    echo

    if [ -n "$LLM_PROVIDER" ]; then
        print_info "Active provider: $LLM_PROVIDER"
        echo

        if has_models_config && is_provider "$LLM_PROVIDER"; then
            local base_url=$(get_provider_config "$LLM_PROVIDER" "base_url")
            local api_key=$(get_provider_config "$LLM_PROVIDER" "api_key")
            echo "Configuration:"
            echo "  base_url: $base_url"
            echo "  api_key: ****"
        else
            local config_file="$CONFIGS_DIR/env.$LLM_PROVIDER"
            if [ -f "$config_file" ]; then
                echo "Configuration file: $config_file"
                echo
                echo "Environment variables from config:"
                grep "^export" "$config_file" | sed 's/^/  /'
            else
                print_warning "Configuration file for $LLM_PROVIDER not found at: $config_file"
            fi
        fi
    else
        print_warning "No configuration is currently active"
    fi

    echo
    echo "Tip: Set env vars to use directly:"
    echo "  export ANTHROPIC_BASE_URL=https://api.example.com"
    echo "  export ANTHROPIC_AUTH_TOKEN=your-api-key"
    echo "  claude  # Run claude directly"
}

load_config() {
    local input="$1"
    shift

    if [ -z "$input" ]; then
        print_error "provider:model is required"
        echo
        print_info "Usage: cc <provider>:<model>"
        echo
        list_configs
        exit 1
    fi

    # Parse provider:model syntax
    if [[ "$input" != *":"* ]]; then
        print_error "Must use provider:model format"
        echo
        print_info "Usage: cc <provider>:<model>"
        echo
        list_configs
        exit 1
    fi

    local provider="${input%%:*}"
    local model="${input#*:}"

    if [ -z "$provider" ] || [ -z "$model" ]; then
        print_error "provider and model cannot be empty"
        echo
        print_info "Usage: cc <provider>:<model>"
        exit 1
    fi

    local claude_args=("$@")

    # Check if provider exists in models.config first, then fall back to env.*
    if has_models_config && is_provider "$provider"; then
        # Validate model exists under provider
        if ! model_exists "$provider" "$model"; then
            print_error "Model '$model' not found under provider '$provider'"
            echo
            print_info "Available models for $provider:"
            for m in $(jq -r ".providers[\"$provider\"].models | keys[]" "$MODELS_CONFIG" 2>/dev/null); do
                echo "  - $provider:$m"
            done
            exit 1
        fi

        local base_url=$(get_provider_config "$provider" "base_url")
        local api_key=$(get_provider_config "$provider" "api_key")

        if [ -z "$base_url" ] || [ -z "$api_key" ]; then
            print_error "Provider '$provider' not found in $MODELS_CONFIG"
            exit 1
        fi

        export ANTHROPIC_BASE_URL="$base_url"
        export ANTHROPIC_AUTH_TOKEN="$api_key"
        export ANTHROPIC_MODEL="$model"

        print_success "Configuration loaded for $provider"
        print_info "Model: $model"

        if [ "$dry_run" = 1 ]; then
            echo
            echo "DRY-RUN: Configuration would be:"
            echo "  ANTHROPIC_BASE_URL=$base_url"
            echo "  ANTHROPIC_AUTH_TOKEN=****"
            echo "  ANTHROPIC_MODEL=$model"
            exit 0
        fi

        echo
        print_success "Now you can use Claude with $provider configuration"
        echo

        if command -v claude &> /dev/null; then
            print_info "Starting Claude CLI..."
            echo
            claude "${claude_args[@]}"
        else
            print_warning "Claude CLI not found in PATH"
            print_info "Make sure Claude CLI is installed"
        fi
    elif [ -f "$CONFIGS_DIR/env.$provider" ]; then
        # Use old-style env.* config
        print_info "Loading configuration for $provider..."
        echo

        source "$CONFIGS_DIR/env.$provider"

        print_success "Configuration loaded for $provider"
        echo

        if [ -n "$model" ]; then
            export ANTHROPIC_MODEL="$model"
            print_info "Model: $model"
        fi

        if [ "$dry_run" = 1 ]; then
            echo
            echo "DRY-RUN: Configuration would be:"
            echo "  ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL:-<not set>}"
            echo "  ANTHROPIC_AUTH_TOKEN=****"
            echo "  ANTHROPIC_MODEL=${ANTHROPIC_MODEL:-<not set>}"
            exit 0
        fi

        if command -v claude &> /dev/null; then
            print_info "Starting Claude CLI..."
            echo
            claude "${claude_args[@]}"
        else
            print_warning "Claude CLI not found in PATH"
        fi
    else
        print_error "Provider '$provider' not found"
        echo
        print_info "Available configurations:"
        list_configs
        exit 1
    fi
}

load_default_config() {
    local args=("$@")

    local default=$(get_default 2>/dev/null || echo "")

    if [ -z "$default" ]; then
        print_error "No default configured in $MODELS_CONFIG"
        echo
        print_info "Please specify provider:model explicitly:"
        echo
        list_configs
        exit 1
    fi

    print_info "Using default: $default"
    echo

    load_config "$default" "${args[@]}"
}

show_usage() {
    echo "Usage: cc [options] <provider>:<model> [arguments...]"
    echo
    echo "Commands:"
    echo "  <provider>:<model> Use specific model (e.g., kimi:kimi-for-coding)"
    echo "  list, ls           List all available configurations"
    echo "  current            Show current configuration"
    echo "  help, -h, --help   Show this help message"
    echo
    echo "Options:"
    echo "  --dry-run           Validate configuration without starting Claude"
    echo
    echo "Configuration:"
    echo "  JSON config: $MODELS_CONFIG"
    echo "  Legacy: $CONFIGS_DIR/env.*"
    echo
    echo "Tip: You can also use existing env vars directly:"
    echo "  export ANTHROPIC_BASE_URL=https://api.example.com"
    echo "  export ANTHROPIC_AUTH_TOKEN=your-api-key"
    echo "  claude  # Run claude directly with your env vars"
    echo
    echo "Examples:"
    echo "  cc                  Use default provider:model"
    echo "  cc kimi:kimi-for-coding  Use kimi provider with kimi-for-coding model"
    echo "  cc --dry-run kimi:kimi-for-coding  Validate without starting Claude"
    echo "  cc list             List all providers and models"
}

main() {
    # Check for jq first
    check_jq

    # Check for --dry-run first and remove it from args
    local new_args=()
    for arg in "$@"; do
        if [ "$arg" = "--dry-run" ]; then
            dry_run=1
        else
            new_args+=("$arg")
        fi
    done
    set -- "${new_args[@]}"

    local command="${1:-}"

    case "$command" in
        help|-h|--help)
            show_usage
            exit 0
            ;;
        list|ls)
            list_configs
            exit 0
            ;;
        current)
            show_current
            exit 0
            ;;
        "")
            load_default_config
            exit $?
            ;;
        *)
            load_config "$command" "${@:2}"
            exit $?
            ;;
    esac
}

main "$@"
